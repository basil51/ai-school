# Copy to repo root as `.env` (next to docker-compose.yml) or use: docker compose --env-file docker/.env

# --- Traefik (must match your running Traefik) ---
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=web
EDUVIBE_HOST=eduvibe.sparkco.localhost

# --- Postgres ---
POSTGRES_USER=eduvibe
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=ai_school

# --- NextAuth (required) ---
# Must match the URL you use in the browser (scheme + host, typically no trailing path).
NEXTAUTH_URL=http://eduvibe.sparkco.localhost
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Optional: skip migrate in entrypoint (debug only; app may error without schema) ---
# SKIP_DB_MIGRATE=true

# If `web` exits with P3009, see comments in docker-compose.yml (migrate resolve or `down -v`).

# --- App secrets (set what you use) ---
OPENAI_API_KEY=
RESEND_API_KEY=
