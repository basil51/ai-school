{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --turbopack -p 3006",
    "build": "next build",
    "start": "next start",
    "worker:start": "tsx src/lib/workers/index.ts",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:load": "jest --testPathPattern=load",
    "test:integration": "jest --testPathPattern=integration",
    "test:automated": "tsx tests/run-tests.ts",
    "test:comprehensive": "tsx tests/run-all-tests.ts",
    "test:all": "npm run test && npm run test:comprehensive",
    "migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:curriculum": "tsx prisma/seed-curriculum.ts",
    "db:seed:chat": "tsx prisma/seed-chat.ts",
    "db:seed:comprehensive": "tsx prisma/seed-comprehensive.ts",
    "db:seed:all": "tsx prisma/seed.ts && tsx prisma/seed-curriculum.ts && tsx prisma/seed-chat.ts && tsx prisma/seed-comprehensive.ts"
  },
